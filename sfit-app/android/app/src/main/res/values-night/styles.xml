<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Modo dark del SO deshabilitado intencionalmente: la app SFIT siempre
      se renderiza en modo claro (themeMode: ThemeMode.light en app.dart).
      Este archivo se igualó a values/styles.xml para que Android NO aplique
      un tema Black al splash ni a las barras del sistema cuando el teléfono
      tiene dark mode global activado.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
