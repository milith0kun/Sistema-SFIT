<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Red ─────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Cámara — QR scanner (mobile_scanner) + fotos de reportes ── -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- ── Galería / fotos — image_picker ───────────────────────────── -->
    <!-- Android ≤12: READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+: permiso granular de imágenes -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- ── Ubicación GPS — geolocator (ciudadano + conductor) ────────── -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Conductor: tracking continuo cuando la app está en background o pantalla bloqueada -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ── Notificaciones push — firebase_messaging ─────────────────── -->
    <!-- Android 13+: solicitud explícita de permiso de notificaciones  -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ── Servicio en primer plano — FCM + GPS en background ───────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+: tipo específico requerido para foreground service con GPS -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Forzar remoción de DATA_SYNC inyectado por dependencias de Firebase -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:node="remove" />

    <!-- ── Exclusión de optimización de batería ──────────────────────── -->
    <!-- Permite a la app pedir al usuario que SFIT no sea suspendida por Doze
         mode durante turnos largos. Justificación regulatoria: fiscalización
         de transporte público requiere tracking GPS continuo (SLA hasta 12h)
         según normativa peruana. Se declara en Play Console Permissions
         Declaration Form. Sin esto, el foreground service queda pausado tras
         minutos sin movimiento y se pierden puntos del recorrido. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
        tools:ignore="BatteryLife" />
    <!-- Requerido por WorkManager para tareas periódicas exactas (watchdog
         que detecta cuando el sistema mató la app durante un turno). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Eliminar ID de publicidad inyectado por dependencias ────────── -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

    <application
        android:label="SFIT"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FCM: servicio en segundo plano para mensajes con app cerrada -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Canal por defecto para FCM. SIN este meta-data, en Android 8+
             cualquier push con `notification` payload se descarta
             silenciosamente porque Firebase no encuentra un canal válido.
             El canal `sfit_alerts` lo crea NotificationService.initialize()
             al boot del app (importancia alta + sonido + vibración). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="sfit_alerts" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <!-- Flutter engine -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Requerido por Flutter para procesar texto seleccionado -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <!-- Para url_launcher: abrir navegador, email, teléfono -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>

</manifest>
